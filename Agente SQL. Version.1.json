    {
      "parameters": {
        "jsCode": "\nconst mensajes = items.map(i => i.json);\n\n// Ordenar por timestamp ascendente\nmensajes.sort((a, b) => new Date(a.timestamp) - new Date(b.timestamp));\n\n// Calcular diferencia con el último mensaje\nconst ultimo = mensajes[mensajes.length - 1];\nconst tiempoUltimo = new Date(ultimo.timestamp).getTime();\nconst tiempoActual = Date.now();\nconst diferencia = tiempoActual - tiempoUltimo;\n\nreturn [{\n  json: {\n    mensajes,\n    usuario_id: mensajes[0]?.usuario_id || null,\n    diferencia_ms: diferencia\n  }\n}];\n\n\n"
      },
